{
    "name": "mnfst",
    "version": "0.5.66",
    "private": false,
    "workspaces": [
        "templates/starter",
        "packages/render"
    ],
    "main": "lib/manifest.js",
    "style": "lib/manifest.css",
    "files": [
        "lib",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "clean": "rimraf src/scripts/manifest.js src/scripts/manifest.render.mjs src/styles/manifest.css src/styles/manifest.min.css src/styles/manifest.code.min.css lib",
        "build": "cd src && node scripts/build.mjs",
        "build:docs": "echo 'Docs is a static website - no build needed'",
        "start:src": "node packages/run/serve.mjs src",
        "start:docs": "node packages/run/serve.mjs docs",
        "start:starter": "node packages/run/serve.mjs templates/starter --port 3001",
        "start:dist": "node packages/run/serve.mjs src/test-prerender --port 5003",
        "prerender": "node src/scripts/manifest.render.mjs --root src",
        "prerender:docs": "node src/scripts/manifest.render.mjs --root docs",
        "prerender:starter": "node src/scripts/manifest.render.mjs --root templates/starter",
        "render": "node src/scripts/manifest.render.mjs --root src",
        "release": "npm version patch --no-git-tag-version && npm publish",
        "release:run": "cd packages/run && npm version patch --no-git-tag-version && npm publish --auth-type=web",
        "release:render": "cd packages/render && npm version patch --no-git-tag-version && npm publish --auth-type=web",
        "release:starter": "cd packages/create-starter && npm version patch --no-git-tag-version && npm publish --auth-type=web",
        "release:all": "npm run release:run && npm run release:render && npm run release:starter && npm run release",
        "prepublishOnly": "npm run build",
        "test": "vitest run",
        "lint": "echo 'No linting configured'"
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^28.0.1",
        "@rollup/plugin-node-resolve": "^15.3.0",
        "@rollup/plugin-terser": "^0.4.4",
        "@tailwindcss/cli": "^4.2.4",
        "cssnano": "^7.1.1",
        "glob": "^11.0.2",
        "puppeteer": "^24.15.0",
        "rimraf": "^5.0.0",
        "rollup": "^4.24.2",
        "tailwindcss": "^4.2.4",
        "vitest": "^4.1.2"
    },
    "keywords": [
        "frontend",
        "framework",
        "css",
        "javascript",
        "ui",
        "components",
        "responsive",
        "modern"
    ],
    "author": "Andrew Matlock",
    "license": "MIT",
    "description": "A modern, lightweight frontend framework with built-in components and utilities",
    "homepage": "https://manifestjs.org",
    "repository": {
        "type": "git",
        "url": "https://github.com/Manifest-X/Manifest.git"
    },
    "bugs": {
        "url": "https://github.com/Manifest-X/Manifest/issues"
    }
}
